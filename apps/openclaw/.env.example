# Copy to ~/.openclaw/.env (chmod 600). Also ensure MyTradingSpace/.env has market data keys.

# Market data (required for pilots / analyze)
POLYGON_API_KEY=
FMP_API_KEY=

# Telegram — daily summary from notify_daily_summary.py / run_daily_pipeline.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional overrides
# MYTRADING_PYTHON=/absolute/path/MyTradingSpace/.venv/bin/python
# SIGNAL_DATE=2026-05-15
# CRON_TZ=America/New_York
# CRON_EXPR=30 6 * * 1-5
