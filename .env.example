# Environment keys for MyTradingSpace

POLYGON_API_KEY=your_polygon_api_key_here
FMP_API_KEY=your_fmp_api_key_here
FRED_API_KEY=your_fred_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- LLM (optional — default deterministic digest, no OpenAI required) ---
# LLM_PROVIDER=deterministic|openai  (default: deterministic — uses agent bullets only)
# LLM_ENABLED=true                   (only when LLM_PROVIDER=openai)
# OPENAI_API_KEY=...                 (only if LLM_PROVIDER=openai)
# LLM_BASE_URL=...                   (OpenAI-compatible endpoint if needed)
# LLM_MODEL=gpt-4o-mini

# --- Free data fallbacks (no paid API required) ---
# MACRO_DATA_SOURCE=auto|fred|yfinance     (default auto: FRED if key, else yfinance ^TNX/^IRX)
# NEWS_DATA_SOURCE=auto|fmp|yfinance       (default auto: FMP if key, else yfinance news)
# INSIDER_DATA_SOURCE=auto|edgar|fmp|yfinance  (default auto: SEC Form 4 EDGAR, then FMP, else yfinance)
# SEC_EDGAR_USER_AGENT=YourName you@email.com   (required by SEC — set contact info)
# GEOPOLITICS_DATA_SOURCE=auto|fmp|yfinance (default auto: FMP if key, else yfinance news scan)
# MARKET_DATA_SOURCE=auto|polygon|yfinance (default auto: Polygon if key, else yfinance ^VIX/SPY/ETFs)
# FRED_API_KEY=...                         (free at https://fred.stlouisfed.org/docs/api/api_key.html)
# FMP_API_KEY=...                          (optional — paid for grades/insider/geo news)
